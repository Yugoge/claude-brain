{
  "env": {
    "REVIEW_GATE_ENABLED": "1",
    "REVIEW_GATE_COMMANDS": "/learn,/ask,/fact-check",
    "REVIEW_GATE_THRESHOLD": "1",
    "ANALYTICS_PERIOD": "90",
    "ANALYTICS_DOMAIN": "finance",
    "PLAYWRIGHT_MCP_SANDBOX": "false"
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "SlashCommand",
      "Task",
      "TodoWrite",
      "Bash(source venv/bin/activate && python3 scripts/review/extract_conversation_context.py:*)",
      "Bash(scripts/learning-materials/update_progress.py:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(source venv/bin/activate:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cat:*)",
      "Bash(cat > /tmp/*.json:*)",
      "Bash(cat > /tmp/*.txt:*)",
      "Bash(cat > /tmp/*.py:*)",
      "Bash(cat > /tmp/*.md:*)",
      "Bash(cargo:*)",
      "Bash(cd:*)",
      "Bash(docker images:*)",
      "Bash(docker logs:*)",
      "Bash(docker ps:*)",
      "Bash(gh auth:*)",
      "Bash(go:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(tree:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(chmod:*)",
      "Bash(test:*)",
      "Bash(grep:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(xargs:*)",
      "Bash(echo:*)",
      "Bash(date:*)",
      "Bash(md5sum:*)",
      "Bash(lsof:*)",
      "Bash(tee:*)",
      "Bash(bash:*)",
      "Bash(for:*)",
      "Bash(do)",
      "Bash(done)",
      "Bash(if:*)",
      "Bash(then)",
      "Bash(else)",
      "Bash(fi)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl get:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(pnpm:*)",
      "Bash(pwd:*)",
      "Bash(rustc:*)",
      "Bash(which:*)",
      "Bash(yarn:*)",
      "Bash(rm -f /tmp/single_page_*.pdf:*)",
      "Bash(rm -f /tmp/*.pdf:*)",
      "Bash(rm -f /tmp/*.tmp:*)",
      "Bash(rm -f /tmp/*.json:*)",
      "Bash(rm:*)",
      "Write(learning-materials/**)",
      "Write(knowledge-base/**)",
      "Write(.review/**)",
      "Write(chats/**)",
      "Write(docs/**)",
      "Write(scripts/**)",
      "Write(/tmp/**)",
      "Edit(learning-materials/**)",
      "Edit(knowledge-base/**)",
      "Edit(.review/**)",
      "Edit(scripts/**)",
      "Edit(docs/**)",
      "Read(//root/**)",
      "Read(//tmp/**)",
      "mcp__memory-server__read_graph",
      "mcp__memory-server__create_entities",
      "mcp__memory-server__search_nodes",
      "mcp__memory-server__delete_entities",
      "mcp__memory-server__create_relations",
      "mcp__memory-server__add_observations",
      "mcp__memory-server__delete_observations",
      "mcp__memory-server__delete_relations",
      "mcp__memory-server__open_nodes",
      "mcp__happy__change_title",
      "mcp__playwright__*",
      "Bash(scripts/playwright-stealth-wrapper.sh:*)",
      "Bash(scripts/test-playwright-ice.sh:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(sudo:*)",
      "Bash(shutdown:*)",
      "Read(.env*)",
      "Write(.env*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
    ],
    "ask": [
      "Bash(pip install:*)",
      "Bash(pip3 install:*)",
      "Bash(rm -rf:*)",
      "Write(.claude/**)",
      "Edit(.claude/**)",
      "Write(*.py)",
      "Edit(*.py)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/scripts/hooks/hook-session-start.py",
            "stdin_json": true,
            "on_error": "ignore"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-info.sh"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-git-init.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/scripts/hooks/hook-record-review-master-call.py",
            "stdin_json": true,
            "on_error": "ignore"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/scripts/hooks/hook-trigger-backlink-rebuild.py",
            "stdin_json": true,
            "on_error": "ignore"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/scripts/hooks/hook-memory-health.py",
            "stdin_json": true,
            "on_error": "ignore"
          }
        ]
      },
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/posttool-todo-tracker.py",
            "stdin_json": true,
            "on_error": "ignore"
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/posttool-todo-count.py",
            "stdin_json": true,
            "on_error": "ignore"
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/posttool-todo-sequence.py",
            "stdin_json": true,
            "on_error": "ignore"
          }
        ]
      },
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/posttool-git-checkpoint.sh"
          }
        ]
      },
      {
        "matcher": "Bash\\(git commit.*\\)",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/posttool-git-warn.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/scripts/hooks/hook-log-review-completion.py",
            "stdin_json": true,
            "on_error": "ignore"
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/scripts/hooks/hook-learn-finalization-prompt.py",
            "stdin_json": true,
            "on_error": "ignore"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/scripts/hooks/hook-session-stop.py",
            "stdin_json": true,
            "on_error": "ignore"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-workflow-enforce.py",
            "stdin_json": true,
            "on_error": "ignore"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-git-commit.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$(date -u +%Y-%m-%dT%H:%M:%SZ) SessionEnd\" >> ~/.claude/session.log"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/prompt-workflow.py",
            "stdin_json": true,
            "on_error": "ignore"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pretool-workflow-gate.py",
            "stdin_json": true,
            "on_error": "ignore"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pretool-bash-safety.sh",
            "stdin_json": true
          }
        ]
      }
    ]
  }
}
